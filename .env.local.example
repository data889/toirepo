# =============================================================
# toirepo · 环境变量参考
# =============================================================
# 复制本文件为 .env.local，按需填值。**不要**把真实 .env.local 提交 git。
#
# 三类分组（决定该变量去 dev / preview / prod 哪个环境）：
#
#   [SERVER-ONLY]    敏感凭据。只在服务器读，绝不通过 NEXT_PUBLIC_* 暴露。
#   [PUBLIC]         需要在浏览器读取，必须以 NEXT_PUBLIC_ 前缀。
#   [BUILD-TIME]     仅 next build 阶段需要（如 next-auth 用来推断 callback URL）。
#
# 生产部署时，对应变量需在 Vercel Dashboard → Settings → Environment Variables
# 配置。完整 prod 变量清单见 docs/VERCEL_ENV.md。
# =============================================================


# ------- [SERVER-ONLY] 数据库 -------
# 本地 Docker PostGIS（端口 5433 避开其他项目的 5432）
# Prod 用 Supabase 提供的两个 URI：
#   - DATABASE_URL  → Transaction pooler URI（端口 6543）
#   - DIRECT_URL    → Direct connection URI（端口 5432，给 prisma migrate 用）
DATABASE_URL="postgresql://toirepo:toirepo@localhost:5433/toirepo?schema=public"
DIRECT_URL="postgresql://toirepo:toirepo@localhost:5433/toirepo?schema=public"


# ------- [SERVER-ONLY] Auth.js -------
AUTH_SECRET=""                # `openssl rand -hex 32`
AUTH_GOOGLE_ID=""             # Google Cloud Console → OAuth 客户端 ID
AUTH_GOOGLE_SECRET=""         # 同上 secret


# ------- [BUILD-TIME] Auth.js -------
# next-auth v5 用 AUTH_URL 推断 OAuth callback。dev=localhost, prod=正式域名,
# preview=Vercel 自动注入的 VERCEL_URL（next-auth v5 有 fallback 逻辑能识别）。
AUTH_URL="http://localhost:3000"


# ------- [SERVER-ONLY] Cloudflare R2 凭据 -------
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="toirepo-tiles"          # pmtiles basemap bucket (T3.1)
R2_PHOTOS_BUCKET_NAME="toirepo-photos"  # 用户上传照片 bucket (M5+)
R2_PUBLIC_URL=""                        # 例如 https://photos.toirepo.com（CDN 公网路径，server 渲染用）


# ------- [PUBLIC] R2 公网 URL -------
# Client-side 通过 NEXT_PUBLIC_ 读取（MapCanvas fallback pmtiles:// URL 用）。
# 必须等于 R2_PUBLIC_URL 的值。
# 如果 NEXT_PUBLIC_MAPTILER_KEY 已设置，地图走 MapTiler 全球底图，此值仅在
# 无 MapTiler key 时作为本地 dev fallback（东京 only）。
NEXT_PUBLIC_R2_PUBLIC_URL=""


# ------- [PUBLIC] MapTiler API key -------
# MapTiler 免费账号 key，用于拉取全球底图 style.json。注册 https://cloudflare.com/account
# 后从 "API keys" 页面复制。Free tier 每月 100k tile 请求，MVP 流量够用。
# 如果不设置，地图回退到 R2 自托管 tokyo.pmtiles（仅东京覆盖 + MAX_BOUNDS）。
# Style id 硬编码为 basic-v2-light（纸色底图，贴近 toirepo 视觉）。
NEXT_PUBLIC_MAPTILER_KEY=""


# ------- [PUBLIC] 站点规范 URL -------
# 用于 metadataBase / sitemap / robots / hreflang。Prod=https://toirepo.com。
# 本地开发留空 → fallback 到 http://localhost:3000。
NEXT_PUBLIC_SITE_URL=""


# ------- [SERVER-ONLY] AI / 翻译 -------
ANTHROPIC_API_KEY=""          # Claude Haiku 4.5 审核
DEEPL_API_KEY=""              # M8 翻译（M10 P1 暂不阻塞）


# ------- [SERVER-ONLY] 邮件 -------
RESEND_API_KEY=""             # Magic-link 登录邮件
# M10 P2: AUTH_RESEND_FROM is the authoritative "from" for magic-link
# emails. Must be a verified address on a Resend-verified domain. If
# unset, auth.ts falls back to EMAIL_FROM (pre-M10 var, kept for
# back-compat) then hard-defaults to noreply@toirepo.com.
AUTH_RESEND_FROM="noreply@toirepo.com"
EMAIL_FROM="noreply@toirepo.com"  # deprecated alias of AUTH_RESEND_FROM, still read as fallback


# ------- [SERVER-ONLY] Upstash Rate Limit -------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""


# ------- [SERVER-ONLY] 监控（M10 P2） -------
# Sentry 留 P2 接，本轮不强制。
SENTRY_DSN=""


# ------- [PUBLIC] PostHog 产品分析 -------
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
