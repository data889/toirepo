# 本地开发环境变量示例
# 复制此文件为 .env.local 并按需填值。不要把真实 .env.local 提交到 git。

# 数据库（本地 Docker PostGIS，端口 5433 避开其他项目的 5432）
DATABASE_URL="postgresql://toirepo:toirepo@localhost:5433/toirepo?schema=public"
DIRECT_URL="postgresql://toirepo:toirepo@localhost:5433/toirepo?schema=public"

# Auth.js（M2 配置时填）
AUTH_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_URL="http://localhost:3000"

# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="toirepo-photos"
R2_PUBLIC_URL=""

# Public-safe copy of R2_PUBLIC_URL for client-side use.
# Must equal R2_PUBLIC_URL. Exposed to browser via NEXT_PUBLIC_ prefix —
# read by src/components/map/MapCanvas.tsx (T3.4) to template the
# pmtiles:// URL in public/map-style/toirepo-paper.json at runtime.
NEXT_PUBLIC_R2_PUBLIC_URL=""

# AI
ANTHROPIC_API_KEY=""
DEEPL_API_KEY=""

# Email
RESEND_API_KEY=""
EMAIL_FROM="noreply@toirepo.app"

# Rate limit
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Monitoring
SENTRY_DSN=""
NEXT_PUBLIC_POSTHOG_KEY=""
