{
  "name": "toirepo",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "smoke:db": "tsx --env-file=.env.local scripts/smoke-test-db.ts",
    "smoke:ratelimit": "tsx --env-file=.env.local scripts/smoke-test-ratelimit.ts",
    "smoke:r2": "tsx --env-file=.env.local scripts/smoke-test-r2-upload.ts",
    "pmtiles:install": "bash scripts/install-pmtiles.sh",
    "pmtiles:download": "bash scripts/download-pmtiles.sh",
    "pmtiles:extract": "bash scripts/extract-tokyo-pmtiles.sh",
    "pmtiles:upload": "tsx --env-file=.env.local scripts/upload-pmtiles.ts",
    "pmtiles:verify": "tsx --env-file=.env.local scripts/verify-pmtiles.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "auth:check": "tsx --env-file=.env.local scripts/auth-db-check.ts",
    "icons:generate": "tsx scripts/generate-toilet-icons.ts",
    "gen:icons": "tsx scripts/gen-icons.ts",
    "seed": "tsx --env-file=.env.local prisma/seed.ts",
    "test:moderation": "tsx --env-file=.env.local scripts/test-moderation.ts",
    "osm:dryrun": "tsx --env-file=.env.local scripts/osm-import-dryrun.ts",
    "osm:import": "tsx --env-file=.env.local scripts/osm-import.ts",
    "osm:import:dryrun": "tsx --env-file=.env.local scripts/osm-import.ts --dry-run",
    "osm:import-global": "tsx --env-file=.env.local scripts/osm-import-global.ts",
    "osm:import-global:dryrun": "tsx --env-file=.env.local scripts/osm-import-global.ts --dry-run",
    "prod:migrate": "tsx scripts/prod-migrate.ts",
    "prod:migrate-drift": "tsx scripts/prod-migrate-drift.ts",
    "prod:healthcheck": "tsx scripts/prod-healthcheck.ts",
    "prod:backfill-location": "tsx scripts/backfill-toilet-location.ts",
    "deepl:translate": "tsx --env-file=.env.local scripts/translate-missing-names.ts",
    "sentry:test": "tsx --env-file=.env.local scripts/sentry-test.ts",
    "prepare": "husky",
    "postinstall": "prisma generate"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/s3-request-presigner": "^3.1032.0",
    "@base-ui/react": "^1.4.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@prisma/client-runtime-utils": "^7.7.0",
    "@sentry/nextjs": "^10.49.0",
    "@serwist/next": "^9.5.7",
    "@tanstack/react-query": "^5.99.0",
    "@trpc/client": "^11.16.0",
    "@trpc/next": "^11.16.0",
    "@trpc/react-query": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "deepl-node": "^1.26.0",
    "exifr": "^7.1.3",
    "lucide-react": "^1.8.0",
    "maplibre-gl": "^5.23.0",
    "next": "16.2.4",
    "next-auth": "5.0.0-beta.31",
    "next-intl": "^4.9.1",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "pmtiles": "^4.4.1",
    "posthog-js": "^1.369.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "react-map-gl": "^8.1.1",
    "resend": "^6.12.0",
    "shadcn": "^4.3.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.17",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.1.4",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^7.7.0",
    "serwist": "^9.5.7",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma",
      "@parcel/watcher",
      "@swc/core",
      "@sentry/cli",
      "core-js",
      "protobufjs",
      "esbuild"
    ]
  }
}
