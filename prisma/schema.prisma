// prisma/schema.prisma
// Full SPEC §5.2 schema.
// Prisma 7: connection URLs live in prisma.config.ts (not datasource here),
// and PostGIS is created/managed via migration SQL rather than Prisma's
// `extensions` preview feature.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  // Prisma 7: url / directUrl live in prisma.config.ts, not here.
  // PrismaClient is constructed with a `pg` adapter; migrations run via
  // prisma.config.ts's migrations.adapter.
  //
  // PostGIS extension is NOT declared here (`extensions = [postgis]` would
  // require the `postgresqlExtensions` preview feature, still preview in
  // v7.x). The extension is created explicitly in the init migration SQL
  // (CREATE EXTENSION IF NOT EXISTS postgis) which works across fresh
  // Postgres, Supabase, and any compatible provider.
  provider = "postgresql"
}

// ============================================================
// 用户与认证
// ============================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  locale        String    @default("zh-CN")
  role          UserRole  @default(USER)

  trustLevel          Int @default(0)
  approvedSubmissions Int @default(0)
  rejectedSubmissions Int @default(0)
  // M7 P1: guard so the auto-upgrade pass runs once per state change
  // (set false after every approvedSubmissions increment; the trust
  // recalculator sets true when it's done).
  autoTrustChecked Boolean @default(true)

  bannedAt  DateTime?
  banReason String?

  accounts      Account[]
  sessions      Session[]
  toilets       Toilet[]       @relation("SubmittedBy")
  photos        Photo[]
  reviews       Review[]
  confirmations Confirmation[]
  appeals       Appeal[]       @relation("AppealAuthor")
  resolvedAppeals Appeal[]     @relation("AppealResolver")
  // M7 P1.5: back-ref for Toilet.lastCommunityEditByUser.
  communityEditedToilets Toilet[] @relation("ToiletCommunityEditor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  USER
  TRUSTED_USER
  MODERATOR
  SENIOR_MODERATOR
  ADMIN
}

// Auth.js 标准表（PrismaAdapter 要求）

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// 厕所核心实体
// ============================================================

model Toilet {
  id   String @id @default(cuid())
  slug String @unique

  // Optional at Prisma schema level so `db.toilet.create()` works without
  // requiring a client-provided location; the DB column is still NOT NULL
  // and is populated by the BEFORE INSERT trigger from latitude/longitude.
  // Intentional schema ↔ DB drift; see v1.1 change note #8.
  location  Unsupported("geography(Point, 4326)")?
  latitude  Float
  longitude Float

  type ToiletType

  name     Json
  address  Json
  building Json?
  floor    String?

  stationGateSide StationGateSide?

  isFree           Boolean @default(true)
  requiresPurchase Boolean @default(false)
  requiresKey      Boolean @default(false)
  is24Hours        Boolean @default(false)

  hasAccessible    Boolean @default(false)
  hasBabyChanging  Boolean @default(false)
  hasKidsToilet    Boolean @default(false)
  hasWashlet       Boolean @default(false)
  hasGenderNeutral Boolean @default(false)
  hasFamilyRoom    Boolean @default(false)

  stallCount StallCount?

  openingHours Json?

  accessNote Json?

  source        ToiletSource @default(USER_SUBMISSION)
  osmId         String?      @unique
  submittedById String?
  submittedBy   User?        @relation("SubmittedBy", fields: [submittedById], references: [id])

  status      ToiletStatus @default(PENDING)
  publishedAt DateTime?

  cleanliness     Float?
  reviewCount     Int       @default(0)
  photoCount      Int       @default(0)
  lastConfirmedAt DateTime?

  // M7 P1.5: community edit trail. When an Appeal of type SUGGEST_EDIT
  // is UPHELD, the Toilet row is mutated and these columns record what
  // happened. originalOsmTags snapshots the pre-edit OSM tags ONLY on
  // the first community edit of an OSM-sourced row, so we can audit or
  // roll back divergence from upstream.
  lastCommunityEditAt     DateTime?
  lastCommunityEditBy     String?
  lastCommunityEditByUser User?     @relation("ToiletCommunityEditor", fields: [lastCommunityEditBy], references: [id])
  originalOsmTags         Json?

  photos        Photo[]
  reviews       Review[]
  confirmations Confirmation[]
  auditLogs     AuditLog[]
  disputes      OwnerDispute[]
  moderation    ToiletModeration?
  appeals       Appeal[]          @relation("AppealTarget")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, status])
  @@index([status, publishedAt])
  @@index([osmId])
}

enum ToiletStatus {
  PENDING
  APPROVED
  REJECTED
  HIDDEN
  ARCHIVED
  // M7 P1.5: community-reported states. Unlike REJECTED (hard hide),
  // these two stay visible on the map with a dimmed / warning treatment
  // (UI in M7 P2). Distinguish "shop is gone entirely" from "shop
  // exists but has no toilet / refuses non-customers".
  CLOSED
  NO_TOILET_HERE
}

enum ToiletSource {
  OSM_IMPORT
  USER_SUBMISSION
  ADMIN_CREATED
}

enum ToiletType {
  PUBLIC
  MALL
  KONBINI
  PURCHASE
}

enum StationGateSide {
  INSIDE
  OUTSIDE
  BOTH
}

enum StallCount {
  SMALL
  MEDIUM
  LARGE
}

// ============================================================
// AI 审核记录
// ============================================================

// 1:1 with Toilet — one current AI moderation result per submission.
// Upserted by moderateToilet(); preserved on re-runs via update branch
// so history isn't stored (if we need per-run audit, migrate to 1:N).
model ToiletModeration {
  id       String @id @default(cuid())
  toiletId String @unique
  toilet   Toilet @relation(fields: [toiletId], references: [id], onDelete: Cascade)

  decision   ModerationDecision
  confidence Float
  // string[] from Haiku; typed via ModerationResult in app layer
  reasons Json
  // { photo_not_toilet: bool, name_spam_or_gibberish: bool, ... }
  issues Json

  model        String
  inputTokens  Int
  outputTokens Int
  // Full raw model text — kept for debugging/audit when the parsed
  // decision looks surprising. Bounded: Haiku max_tokens=512.
  rawText String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([decision])
  @@index([confidence])
  @@index([createdAt])
}

enum ModerationDecision {
  APPROVED
  REJECTED
  NEEDS_HUMAN
}

// ============================================================
// 照片
// ============================================================

model Photo {
  id       String @id @default(cuid())
  toiletId String
  toilet   Toilet @relation(fields: [toiletId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id])

  url          String
  thumbnailUrl String
  width        Int
  height       Int
  sizeBytes    Int

  category PhotoCategory @default(ENTRANCE)

  status            PhotoStatus @default(PENDING)
  aiPrescreenResult Json?
  rejectedReason    String?

  createdAt DateTime @default(now())

  @@index([toiletId, status])
}

enum PhotoCategory {
  ENTRANCE
  SIGNAGE
  EXTERIOR
  BUILDING
}

enum PhotoStatus {
  PENDING
  APPROVED
  REJECTED
}

// ============================================================
// 评论
// ============================================================

// M7 P1 reshape: rating + body + photoKeys (replaces v1 cleanliness+comment).
// Moderation fields inlined (not poly-fk'd to ToiletModeration) — simpler
// than a cross-model join, and review moderation is a different query
// target than toilet moderation anyway.
model Review {
  id       String @id @default(cuid())
  toiletId String
  toilet   Toilet @relation(fields: [toiletId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id])

  rating    Int // 1..5; enforced in tRPC + app layer
  body      String?  @db.Text
  photoKeys String[] // R2 keys (originals), reuses M5 upload pipeline

  status ReviewStatus @default(PENDING)

  // Inlined Haiku moderation (mirror of ToiletModeration for reviews)
  aiDecision     ModerationDecision?
  aiConfidence   Float?
  aiReasons      Json?
  aiRawText      String?             @db.Text
  aiModeratedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([toiletId, userId])
  @@index([toiletId, status])
  @@index([status, createdAt])
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  HIDDEN // admin-hidden (not AI-rejected; preserves row for audit)
}

// ============================================================
// 确认（"这里还能用"）
// ============================================================

// M7 P1 reshape: toggle semantics. One row = "this user says this toilet
// still exists". No stillAvailable / note fields — the row's existence
// IS the signal. Unique(toiletId, userId) enforces toggle: create on
// first toggle, delete on second.
model Confirmation {
  id       String @id @default(cuid())
  toiletId String
  toilet   Toilet @relation(fields: [toiletId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([toiletId, userId])
  @@index([toiletId])
  @@index([userId, createdAt])
}

// ============================================================
// 店家申诉
// ============================================================

model OwnerDispute {
  id       String @id @default(cuid())
  toiletId String
  toilet   Toilet @relation(fields: [toiletId], references: [id])

  claimerEmail String
  claimerName  String
  claimerRole  String
  reason       String   @db.Text
  evidenceUrls String[]

  status       DisputeStatus @default(PENDING)
  resolvedAt   DateTime?
  resolvedNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum DisputeStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_INFO
}

// ============================================================
// 用户 Appeal (M7 P1 + P1.5) — 与 OwnerDispute 区分：
//   OwnerDispute: 店主来申诉"我不想我的店被列"
//   Appeal:       所有用户对已有数据的 变更/举报/撤回 请求，通过 AppealType
//                 6 种类型覆盖，走 admin 审核 + Haiku AI 预审参考。
// 二者路由 / 权限 / UI 都不同，刻意独立存在。
// ============================================================

model Appeal {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("AppealAuthor", fields: [userId], references: [id], onDelete: Cascade)

  type           AppealType
  targetToiletId String?
  targetToilet   Toilet?    @relation("AppealTarget", fields: [targetToiletId], references: [id], onDelete: Cascade)
  // All 6 AppealTypes target a Toilet row (REJECTED submissions are still
  // in the Toilet table). A separate targetSubmissionId column is
  // deliberately NOT added — semantics ride on `type` + targetToiletId.
  // A CHECK constraint in the migration enforces targetToiletId NOT NULL.

  reason   String   @db.Text
  evidence String[] // R2 photo keys (optional)

  // SUGGEST_EDIT only: partial Toilet update payload (name / address /
  // type / floor / hours). Validated at the application layer against a
  // zod allowlist; DB CHECK enforces non-null when type is SUGGEST_EDIT.
  // NULL for all other AppealTypes.
  proposedChanges Json?

  // Haiku pre-screen (P1.5). Writes by moderateAppeal for admin reference.
  // Does NOT auto-resolve — admin still decides every case.
  aiDecision    ModerationDecision?
  aiConfidence  Float?
  aiReasons     Json?
  aiRawText     String?             @db.Text
  aiModeratedAt DateTime?

  status         AppealStatus @default(PENDING)
  resolutionNote String?      @db.Text
  resolvedById   String?
  resolvedBy     User?        @relation("AppealResolver", fields: [resolvedById], references: [id])
  resolvedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([userId])
  @@index([targetToiletId])
  @@index([type, status])
}

enum AppealType {
  OWN_SUBMISSION_REJECT // my submission got rejected — please reconsider
  REPORT_DATA_ERROR     // someone else's approved entry is factually wrong
  SUGGEST_EDIT          // propose a field-level edit (uses proposedChanges)
  REPORT_CLOSED         // the business is physically closed
  REPORT_NO_TOILET      // the business exists but has no toilet / non-customer refused
  SELF_SOFT_DELETE      // author wants their own submission hidden (via review)
}

enum AppealStatus {
  PENDING
  UPHELD    // admin agreed: reject→approved OR approved→rejected
  DISMISSED // admin disagreed; no state change
}

// ============================================================
// 审计日志
// ============================================================

model AuditLog {
  id       String  @id @default(cuid())
  toiletId String?
  toilet   Toilet? @relation(fields: [toiletId], references: [id])
  actorId  String?
  action   String
  metadata Json?

  createdAt DateTime @default(now())

  @@index([toiletId])
  @@index([actorId])
}
