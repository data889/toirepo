// prisma/schema.prisma
// Full SPEC §5.2 schema.
// Prisma 7: connection URLs live in prisma.config.ts (not datasource here),
// and PostGIS is created/managed via migration SQL rather than Prisma's
// `extensions` preview feature.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  // Prisma 7: url / directUrl live in prisma.config.ts, not here.
  // PrismaClient is constructed with a `pg` adapter; migrations run via
  // prisma.config.ts's migrations.adapter.
  //
  // PostGIS extension is NOT declared here (`extensions = [postgis]` would
  // require the `postgresqlExtensions` preview feature, still preview in
  // v7.x). The extension is created explicitly in the init migration SQL
  // (CREATE EXTENSION IF NOT EXISTS postgis) which works across fresh
  // Postgres, Supabase, and any compatible provider.
  provider = "postgresql"
}

// ============================================================
// 用户与认证
// ============================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  locale        String    @default("zh-CN")
  role          UserRole  @default(USER)

  trustLevel          Int @default(0)
  approvedSubmissions Int @default(0)
  rejectedSubmissions Int @default(0)
  // M7 P1: guard so the auto-upgrade pass runs once per state change
  // (set false after every approvedSubmissions increment; the trust
  // recalculator sets true when it's done).
  autoTrustChecked Boolean @default(true)

  bannedAt  DateTime?
  banReason String?

  accounts      Account[]
  sessions      Session[]
  toilets       Toilet[]       @relation("SubmittedBy")
  photos        Photo[]
  reviews       Review[]
  confirmations Confirmation[]
  appeals       Appeal[]       @relation("AppealAuthor")
  resolvedAppeals Appeal[]     @relation("AppealResolver")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  USER
  TRUSTED_USER
  MODERATOR
  SENIOR_MODERATOR
  ADMIN
}

// Auth.js 标准表（PrismaAdapter 要求）

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// 厕所核心实体
// ============================================================

model Toilet {
  id   String @id @default(cuid())
  slug String @unique

  // Optional at Prisma schema level so `db.toilet.create()` works without
  // requiring a client-provided location; the DB column is still NOT NULL
  // and is populated by the BEFORE INSERT trigger from latitude/longitude.
  // Intentional schema ↔ DB drift; see v1.1 change note #8.
  location  Unsupported("geography(Point, 4326)")?
  latitude  Float
  longitude Float

  type ToiletType

  name     Json
  address  Json
  building Json?
  floor    String?

  stationGateSide StationGateSide?

  isFree           Boolean @default(true)
  requiresPurchase Boolean @default(false)
  requiresKey      Boolean @default(false)
  is24Hours        Boolean @default(false)

  hasAccessible    Boolean @default(false)
  hasBabyChanging  Boolean @default(false)
  hasKidsToilet    Boolean @default(false)
  hasWashlet       Boolean @default(false)
  hasGenderNeutral Boolean @default(false)
  hasFamilyRoom    Boolean @default(false)

  stallCount StallCount?

  openingHours Json?

  accessNote Json?

  source        ToiletSource @default(USER_SUBMISSION)
  osmId         String?      @unique
  submittedById String?
  submittedBy   User?        @relation("SubmittedBy", fields: [submittedById], references: [id])

  status      ToiletStatus @default(PENDING)
  publishedAt DateTime?

  cleanliness     Float?
  reviewCount     Int       @default(0)
  photoCount      Int       @default(0)
  lastConfirmedAt DateTime?

  photos        Photo[]
  reviews       Review[]
  confirmations Confirmation[]
  auditLogs     AuditLog[]
  disputes      OwnerDispute[]
  moderation    ToiletModeration?
  appeals       Appeal[]          @relation("AppealTarget")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, status])
  @@index([status, publishedAt])
  @@index([osmId])
}

enum ToiletStatus {
  PENDING
  APPROVED
  REJECTED
  HIDDEN
  ARCHIVED
}

enum ToiletSource {
  OSM_IMPORT
  USER_SUBMISSION
  ADMIN_CREATED
}

enum ToiletType {
  PUBLIC
  MALL
  KONBINI
  PURCHASE
}

enum StationGateSide {
  INSIDE
  OUTSIDE
  BOTH
}

enum StallCount {
  SMALL
  MEDIUM
  LARGE
}

// ============================================================
// AI 审核记录
// ============================================================

// 1:1 with Toilet — one current AI moderation result per submission.
// Upserted by moderateToilet(); preserved on re-runs via update branch
// so history isn't stored (if we need per-run audit, migrate to 1:N).
model ToiletModeration {
  id       String @id @default(cuid())
  toiletId String @unique
  toilet   Toilet @relation(fields: [toiletId], references: [id], onDelete: Cascade)

  decision   ModerationDecision
  confidence Float
  // string[] from Haiku; typed via ModerationResult in app layer
  reasons Json
  // { photo_not_toilet: bool, name_spam_or_gibberish: bool, ... }
  issues Json

  model        String
  inputTokens  Int
  outputTokens Int
  // Full raw model text — kept for debugging/audit when the parsed
  // decision looks surprising. Bounded: Haiku max_tokens=512.
  rawText String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([decision])
  @@index([confidence])
  @@index([createdAt])
}

enum ModerationDecision {
  APPROVED
  REJECTED
  NEEDS_HUMAN
}

// ============================================================
// 照片
// ============================================================

model Photo {
  id       String @id @default(cuid())
  toiletId String
  toilet   Toilet @relation(fields: [toiletId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id])

  url          String
  thumbnailUrl String
  width        Int
  height       Int
  sizeBytes    Int

  category PhotoCategory @default(ENTRANCE)

  status            PhotoStatus @default(PENDING)
  aiPrescreenResult Json?
  rejectedReason    String?

  createdAt DateTime @default(now())

  @@index([toiletId, status])
}

enum PhotoCategory {
  ENTRANCE
  SIGNAGE
  EXTERIOR
  BUILDING
}

enum PhotoStatus {
  PENDING
  APPROVED
  REJECTED
}

// ============================================================
// 评论
// ============================================================

// M7 P1 reshape: rating + body + photoKeys (replaces v1 cleanliness+comment).
// Moderation fields inlined (not poly-fk'd to ToiletModeration) — simpler
// than a cross-model join, and review moderation is a different query
// target than toilet moderation anyway.
model Review {
  id       String @id @default(cuid())
  toiletId String
  toilet   Toilet @relation(fields: [toiletId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id])

  rating    Int // 1..5; enforced in tRPC + app layer
  body      String?  @db.Text
  photoKeys String[] // R2 keys (originals), reuses M5 upload pipeline

  status ReviewStatus @default(PENDING)

  // Inlined Haiku moderation (mirror of ToiletModeration for reviews)
  aiDecision     ModerationDecision?
  aiConfidence   Float?
  aiReasons      Json?
  aiRawText      String?             @db.Text
  aiModeratedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([toiletId, userId])
  @@index([toiletId, status])
  @@index([status, createdAt])
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  HIDDEN // admin-hidden (not AI-rejected; preserves row for audit)
}

// ============================================================
// 确认（"这里还能用"）
// ============================================================

// M7 P1 reshape: toggle semantics. One row = "this user says this toilet
// still exists". No stillAvailable / note fields — the row's existence
// IS the signal. Unique(toiletId, userId) enforces toggle: create on
// first toggle, delete on second.
model Confirmation {
  id       String @id @default(cuid())
  toiletId String
  toilet   Toilet @relation(fields: [toiletId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([toiletId, userId])
  @@index([toiletId])
  @@index([userId, createdAt])
}

// ============================================================
// 店家申诉
// ============================================================

model OwnerDispute {
  id       String @id @default(cuid())
  toiletId String
  toilet   Toilet @relation(fields: [toiletId], references: [id])

  claimerEmail String
  claimerName  String
  claimerRole  String
  reason       String   @db.Text
  evidenceUrls String[]

  status       DisputeStatus @default(PENDING)
  resolvedAt   DateTime?
  resolvedNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum DisputeStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_INFO
}

// ============================================================
// 用户申诉 (M7 P1) — 与 OwnerDispute 区分：
//   OwnerDispute: 业主来申诉"我不想我的店被列"
//   Appeal:       用户自己的提交被 reject → 要求复核 (OWN_SUBMISSION_REJECT)
//                 用户看到他人 approved 的数据是错 → 举报 (BAD_APPROVED_DATA)
// 二者路由 / 权限 / UI 都不同，刻意独立存在。
// ============================================================

model Appeal {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("AppealAuthor", fields: [userId], references: [id], onDelete: Cascade)

  type AppealType
  // Exactly one of these is non-null — enforced via CHECK constraint in
  // migration raw SQL (Prisma doesn't model multi-column CHECKs natively).
  targetToiletId String?
  targetToilet   Toilet? @relation("AppealTarget", fields: [targetToiletId], references: [id], onDelete: Cascade)
  // OWN_SUBMISSION_REJECT's target is also a Toilet row (submissions that
  // became REJECTED). We intentionally don't branch to a separate
  // Submission entity — REJECTED Toilets still exist in the table.

  reason   String   @db.Text
  evidence String[] // R2 photo keys (optional)

  status         AppealStatus @default(PENDING)
  resolutionNote String?      @db.Text
  resolvedById   String?
  resolvedBy     User?        @relation("AppealResolver", fields: [resolvedById], references: [id])
  resolvedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([userId])
  @@index([targetToiletId])
}

enum AppealType {
  OWN_SUBMISSION_REJECT // my submission got rejected — please reconsider
  BAD_APPROVED_DATA     // someone else's approved entry is wrong — please remove
}

enum AppealStatus {
  PENDING
  UPHELD    // admin agreed: reject→approved OR approved→rejected
  DISMISSED // admin disagreed; no state change
}

// ============================================================
// 审计日志
// ============================================================

model AuditLog {
  id       String  @id @default(cuid())
  toiletId String?
  toilet   Toilet? @relation(fields: [toiletId], references: [id])
  actorId  String?
  action   String
  metadata Json?

  createdAt DateTime @default(now())

  @@index([toiletId])
  @@index([actorId])
}
