{
  "version": 8,
  "name": "toirepo-paper",
  "metadata": {
    "toirepo:note": "toirepo-paper v1 — SPEC §4.2 implementation. Authoritative colors live in SPEC §4.2 and mirror src/app/globals.css @theme. Basemap source rolled back to self-hosted R2 (tokyo.pmtiles, 237MB, Tokyo-only) in M10 P2 hotfix: the Protomaps public sample URL we switched to earlier returned 404 — sample snapshots rotate out of their CDN without notice. Global coverage deferred to M12 (either Planetiler self-host, Protomaps paid api.protomaps.com, or a different public pmtiles host). {{R2_PUBLIC_URL}} placeholder is substituted at runtime by src/lib/map/style-loader.ts. Layers target the Protomaps basemaps v4 schema: earth, landcover, landuse, water, buildings, roads, boundaries, places."
  },
  "glyphs": "https://protomaps.github.io/basemaps-assets/fonts/{fontstack}/{range}.pbf",
  "sources": {
    "protomaps": {
      "type": "vector",
      "url": "pmtiles://{{R2_PUBLIC_URL}}/tokyo.pmtiles",
      "attribution": "<a href=\"https://protomaps.com\">Protomaps</a> © <a href=\"https://openstreetmap.org/copyright\">OpenStreetMap</a>"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#FDFCF9" }
    },
    {
      "id": "earth",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "earth",
      "paint": { "fill-color": "#FDFCF9" }
    },
    {
      "id": "landcover",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landcover",
      "filter": ["in", "kind", "wood", "forest", "scrub", "grass", "scrubland", "wetland"],
      "paint": { "fill-color": "#E8EBE0" }
    },
    {
      "id": "landuse_park",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landuse",
      "filter": ["in", "kind", "park", "protected_area", "nature_reserve", "forest", "grass", "wood", "scrub", "meadow"],
      "paint": { "fill-color": "#E8EBE0" }
    },
    {
      "id": "landuse_beach_sand",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landuse",
      "filter": ["in", "kind", "beach", "sand"],
      "paint": { "fill-color": "#E8EBE0" }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "water",
      "paint": { "fill-color": "#E8E4D8" }
    },
    {
      "id": "buildings",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "buildings",
      "minzoom": 14,
      "paint": {
        "fill-color": "#F5F2EA",
        "fill-opacity": {
          "stops": [[14, 0], [15, 0.4], [16, 0.8]]
        }
      }
    },
    {
      "id": "roads_minor_casing",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["in", "kind", "minor_road", "path"],
      "minzoom": 13,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#FDFCF9",
        "line-width": { "stops": [[13, 0.5], [16, 3.0], [18, 6.0]] }
      }
    },
    {
      "id": "roads_minor",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["in", "kind", "minor_road", "path"],
      "minzoom": 13,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#D8D4C8",
        "line-width": { "stops": [[13, 0.3], [16, 1.5], [18, 3.0]] }
      }
    },
    {
      "id": "roads_major_casing",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["in", "kind", "major_road", "highway"],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#FDFCF9",
        "line-width": { "stops": [[9, 0.8], [14, 4.0], [18, 10.0]] }
      }
    },
    {
      "id": "roads_major",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["in", "kind", "major_road", "highway"],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#B8B4A8",
        "line-width": { "stops": [[9, 0.5], [14, 2.5], [18, 6.0]] }
      }
    },
    {
      "id": "roads_rail",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["==", "kind", "rail"],
      "minzoom": 11,
      "paint": {
        "line-color": "#C4A8A0",
        "line-width": { "stops": [[11, 0.5], [16, 1.5]] },
        "line-dasharray": [3, 2]
      }
    },
    {
      "id": "boundaries_country",
      "type": "line",
      "source": "protomaps",
      "source-layer": "boundaries",
      "filter": ["==", "kind", "country"],
      "paint": {
        "line-color": "#C4A8A0",
        "line-width": 0.8,
        "line-dasharray": [2, 1]
      }
    },
    {
      "id": "boundaries_region",
      "type": "line",
      "source": "protomaps",
      "source-layer": "boundaries",
      "filter": ["in", "kind", "region", "county"],
      "minzoom": 7,
      "paint": {
        "line-color": "#C4A8A0",
        "line-width": 0.5,
        "line-dasharray": [1, 1],
        "line-opacity": 0.6
      }
    },
    {
      "id": "place_label_locality",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "places",
      "filter": ["==", "kind", "locality"],
      "minzoom": 6,
      "layout": {
        "text-field": ["coalesce", ["get", "name:ja"], ["get", "name:zh-Hans"], ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": { "stops": [[6, 10], [12, 14], [16, 18]] },
        "text-letter-spacing": 0.1
      },
      "paint": {
        "text-color": "#8A8578",
        "text-halo-color": "#FDFCF9",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place_label_neighbourhood",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "places",
      "filter": ["in", "kind", "neighbourhood", "macrohood"],
      "minzoom": 12,
      "layout": {
        "text-field": ["coalesce", ["get", "name:ja"], ["get", "name:zh-Hans"], ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": { "stops": [[12, 10], [15, 13]] },
        "text-letter-spacing": 0.05
      },
      "paint": {
        "text-color": "#8A8578",
        "text-halo-color": "#FDFCF9",
        "text-halo-width": 1.2
      }
    }
  ]
}
